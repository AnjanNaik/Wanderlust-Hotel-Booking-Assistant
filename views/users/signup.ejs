<% layout("/layouts/boilerplate") %>
<style>
    body {
        overflow-x: hidden;
    }
    .footer-container {
        display: none !important; /* Hide page footer for true edge-to-edge auth experience */
    }
    .container {
        /* Ensure the main container doesn't block edge-to-edge layout */
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }
    .bg-slider-container {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; overflow: hidden;
    }
    .bg-slide {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background-size: cover; background-position: center; background-repeat: no-repeat;
        opacity: 0; transition: opacity 2s ease-in-out; z-index: 1;
    }
    .bg-slide.prev-active { opacity: 1; z-index: 2; }
    .bg-slide.active { opacity: 1; z-index: 3; }
    .auth-bg { background-image: none !important; }
    .auth-overlay { z-index: 3; background: linear-gradient(135deg, rgba(8, 8, 8, 0.7) 0%, rgba(15, 0, 30, 0.6) 100%); }
    .glass-card { 
        z-index: 4; position: relative; 
        background: rgba(19, 19, 19, 0.65) !important;
        backdrop-filter: blur(35px) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 20px !important;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4) !important;
        color: #e5e2e1 !important;
    }
    .cinematic-input {
        background: #0e0e0e !important;
        border: 1px solid #353534 !important;
        color: #e5e2e1 !important;
        border-radius: 12px !important;
        transition: all 0.3s ease !important;
    }
    .cinematic-input::placeholder {
        color: rgba(255, 255, 255, 0.65) !important;
        font-weight: 500 !important;
    }
    .cinematic-input:focus {
        border-color: #4f46e5 !important;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.15) !important;
        background: #131313 !important;
    }
    .cinematic-btn {
        background: #4f46e5 !important;
        color: #ffffff !important;
        border-radius: 20px !important;
        border: none !important;
        font-weight: 600 !important;
        text-transform: none !important;
        letter-spacing: 0.5px !important;
        transition: transform 0.2s, box-shadow 0.2s !important;
    }
    .cinematic-btn:hover {
        transform: translateY(-2px) !important;
        box-shadow: 0 8px 25px rgba(79, 70, 229, 0.35) !important;
    }
    .cinematic-link { color: #c3c0ff !important; transition: text-shadow 0.3s ease; }
    .cinematic-link:hover { color: #e2dfff !important; text-shadow: 0 0 10px rgba(195, 192, 255, 0.5); }
</style>
<div class="auth-bg">
    <div class="bg-slider-container" id="dynamicAuthBg"></div>
    <div class="auth-overlay"></div>
    <div class="glass-card fade-up">
        <div class="text-center mb-4">
            <div class="auth-brand-logo mb-3" style="font-size: 2.5rem; color: #4f46e5;">
                <i class="fa-regular fa-compass"></i>
            </div>
            <h2 style="font-weight: 700; font-family: 'Outfit', 'Inter', sans-serif; font-size: 2rem; margin-bottom: 5px; letter-spacing: -1px; text-shadow: 0 4px 10px rgba(0,0,0,0.5);">Join the Journey</h2>
            <p style="font-size: 0.95rem; opacity: 0.85; font-family: 'Inter', sans-serif;">Create an account to reserve exclusive locations.</p>
        </div>

        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="mb-3 position-relative d-flex align-items-center">
                <div class="position-absolute d-flex justify-content-center align-items-center" style="width: 3rem; height: 100%; left: 0; pointer-events: none;">
                    <i class="fa-solid fa-user" style="color: rgba(255,255,255,0.7); font-size: 1.05rem;"></i>
                </div>
                <input name="username" id="username" type="text" class="form-control cinematic-input shadow-none" style="padding-left: 2.8rem !important; height: 3.2rem;" placeholder="Choose a username" required>
            </div>

            <div class="mb-3 position-relative d-flex align-items-center">
                <div class="position-absolute d-flex justify-content-center align-items-center" style="width: 3rem; height: 100%; left: 0; pointer-events: none;">
                    <i class="fa-solid fa-envelope" style="color: rgba(255,255,255,0.7); font-size: 1.05rem;"></i>
                </div>
                <input name="email" id="email" type="email" class="form-control cinematic-input shadow-none" style="padding-left: 2.8rem !important; height: 3.2rem;" placeholder="Email address" required>
            </div>

            <div class="mb-4 position-relative d-flex align-items-center">
                <div class="position-absolute d-flex justify-content-center align-items-center" style="width: 3rem; height: 100%; left: 0; pointer-events: none;">
                    <i class="fa-solid fa-lock" style="color: rgba(255,255,255,0.7); font-size: 1.05rem;"></i>
                </div>
                <input name="password" id="password" type="password" class="form-control cinematic-input shadow-none" style="padding-left: 2.8rem !important; height: 3.2rem;" placeholder="Create a password" required>
            </div>

            <button type="submit" class="btn cinematic-btn w-100 mb-4 py-2">Create Account</button>
        </form>

        <div class="text-center auth-footer-text" style="font-family: 'Inter', sans-serif;">
            Already have an account? <a href="/login" class="fw-bold cinematic-link text-decoration-none">Sign In</a>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const bgImages = [
            'https://images.unsplash.com/photo-1571896349842-33c89424de2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80',
            'https://images.unsplash.com/photo-1542314831-c6a4d2759827?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80',
            'https://images.unsplash.com/photo-1510798831971-661eb04b3739?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80',
            'https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80',
            'https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80'
        ];
        
        const container = document.getElementById('dynamicAuthBg');
        let slides = [];
        
        // Generate DOM elements for cross-fade
        bgImages.forEach((src, index) => {
            const slide = document.createElement('div');
            slide.className = 'bg-slide' + (index === 0 ? ' active' : '');
            slide.style.backgroundImage = `url('${src}')`;
            container.appendChild(slide);
            slides.push(slide);
            
            // Preload image
            const img = new Image();
            img.src = src;
        });

        let currentIndex = 0;
        setInterval(() => {
            const prevSlide = slides[currentIndex];
            prevSlide.classList.remove('active');
            prevSlide.classList.add('prev-active');
            
            currentIndex = (currentIndex + 1) % slides.length;
            slides[currentIndex].classList.add('active');
            
            setTimeout(() => {
                prevSlide.classList.remove('prev-active');
            }, 2000);
        }, 4000); // Smooth, majestic transition every 4 seconds
    });
</script>