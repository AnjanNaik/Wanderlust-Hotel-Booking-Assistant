<% layout("/layouts/boilerplate")%>

<style>
    .trip-card-lux {
        background: white;
        border-radius: 28px;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.04);
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: flex;
        flex-direction: row;
        margin-bottom: 2rem;
    }

    .trip-card-lux:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    }

    .trip-img-container {
        width: 320px;
        min-width: 320px;
        height: auto;
        overflow: hidden;
    }

    .trip-img-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1s ease;
    }

    .trip-card-lux:hover .trip-img-container img {
        transform: scale(1.05);
    }

    .trip-content {
        flex: 1;
        padding: 2rem;
        display: flex;
        flex-direction: column;
    }

    .trip-badge {
        padding: 6px 16px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .trip-title {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        font-size: 1.4rem;
        color: #1a1a1a;
        margin-bottom: 0.5rem;
    }

    .trip-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.85rem;
        color: #666;
        margin-bottom: 1.5rem;
    }

    .trip-detail-pill {
        background: #fdfcfb;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 10px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.85rem;
        color: #1a1a1a;
        margin-bottom: 1.5rem;
    }

    .trip-detail-pill div .label {
        font-size: 0.65rem;
        text-transform: uppercase;
        font-weight: 800;
        color: #94a3b8;
    }

    .trip-detail-pill div .value {
        font-weight: 700;
        color: #1e293b;
    }

    .btn-trip-action {
        border-radius: 50px;
        padding: 10px 24px;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        transition: all 0.3s ease;
    }

    .btn-view-stay {
        border: 1.5px solid var(--luxury-pink);
        color: var(--luxury-pink);
        background: transparent;
    }

    .btn-view-stay:hover {
        background: var(--luxury-pink);
        color: white;
    }

    .btn-cancel-stay {
        background: #fff5f5;
        color: #e53e3e;
        border: none;
    }

    .btn-cancel-stay:hover {
        background: #fee2e2;
    }

    @media (max-width: 991px) {
        .trip-card-lux { flex-direction: column; }
        .trip-img-container { width: 100%; height: 200px; }
    }
</style>

<div class="container mt-5 mb-5 pb-5 dashboard-container">
    <div class="mb-5">
        <h1 class="fw-bold mb-1" style="background: linear-gradient(to right, var(--luxury-pink), var(--luxury-gold)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">My Trips</h1>
        <p class="text-muted">Explore your past and upcoming adventures.</p>
    </div>

    <% if (bookings && bookings.length > 0) { %>
        <div class="row">
            <% for(let booking of bookings){ %>
                <div class="col-12 fade-up">
                    <div class="trip-card-lux">
                        <div class="trip-img-container">
                            <img src="<%= booking.listing.image.url %>" alt="listing_image">
                        </div>
                        <div class="trip-content">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="trip-title"><%= booking.listing.title %></h5>
                                <span class="trip-badge <%= booking.status === 'Confirmed' ? 'bg-success-subtle text-success' : 'bg-warning-subtle text-warning' %>">
                                    <%= booking.status %>
                                </span>
                            </div>
                            
                            <div class="trip-meta">
                                <span><i class="fa-solid fa-location-dot me-1 text-hotel-pink opacity-75"></i> <%= booking.listing.location %>, <%= booking.listing.country %></span>
                                <span style="opacity: 0.3;">|</span>
                                <span>Hosted by <b class="text-dark"><%= booking.listing.owner ? booking.listing.owner.username : 'Boutique' %></b></span>
                            </div>

                            <div class="d-flex flex-wrap gap-3">
                                <div class="trip-detail-pill">
                                    <i class="fa-regular fa-calendar-check fs-5 opacity-50"></i>
                                    <div>
                                        <div class="label">Duration</div>
                                        <div class="value">
                                            <%= booking.checkIn.toLocaleDateString('en-US', {month: 'short', day: '2-digit'}) %> - 
                                            <%= booking.checkOut.toLocaleDateString('en-US', {month: 'short', day: '2-digit', year: 'numeric'}) %>
                                        </div>
                                    </div>
                                </div>
                                <div class="trip-detail-pill">
                                    <i class="fa-solid fa-users fs-5 opacity-50"></i>
                                    <div>
                                        <div class="label">Guests</div>
                                        <div class="value"><%= booking.guests || 1 %> People</div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <div class="price-row m-0">
                                    <span class="price-large">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                    <span class="price-unit">Total Stay</span>
                                </div>
                                <div class="d-flex gap-3">
                                    <a href="/listings/<%= booking.listing._id %>" class="btn btn-trip-action btn-view-stay">View Suite</a>
                                    <form method="POST" action="/bookings/<%= booking._id %>?_method=DELETE" class="m-0">
                                        <button class="btn btn-trip-action btn-cancel-stay">Cancel Journey</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } else { %>
        <div class="text-center py-5 mt-5">
            <div class="bg-white p-5 rounded-4 border shadow-sm mx-auto" style="max-width: 500px; border-style: dashed !important;">
                <i class="fa-solid fa-suitcase-rolling display-2 text-muted opacity-25 mb-4"></i>
                <h3 class="fw-bold">No trips planned... yet!</h3>
                <p class="text-muted mb-4 px-4">Time to dust off your bags and start planning your next journey into paradise.</p>
                <a href="/listings" class="btn btn-luxury-pill">Explore Destinations</a>
            </div>
        </div>
    <% } %>
</div>
